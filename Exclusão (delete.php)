<?php
require_once 'config.php';
session_start();

// Só aceita requisições POST (não GET)
if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
    header('Location: listar.php');
    exit;
}

$id = isset($_POST['id']) ? (int)$_POST['id'] : 0;

if ($id <= 0) {
    $_SESSION['msg'] = "ID inválido!";
    header('Location: listar.php');
    exit;
}

try {
    // Verificar se paciente existe
    $check = $pdo->prepare("SELECT id FROM pacientes WHERE id = :id");
    $check->execute([':id' => $id]);
    
    if (!$check->fetch()) {
        $_SESSION['msg'] = "Paciente não encontrado!";
        header('Location: listar.php');
        exit;
    }
    
    // Excluir
    $sql = "DELETE FROM pacientes WHERE id = :id";
    $stmt = $pdo->prepare($sql);
    $stmt->execute([':id' => $id]);
    
    $_SESSION['msg'] = "Paciente excluído permanentemente.";
    header('Location: listar.php');
    exit;
    
} catch (PDOException $e) {
    $_SESSION['msg'] = "Erro ao excluir paciente!";
    header('Location: listar.php');
    exit;
}
?>
